{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zenlist",
  "version": "0.1.0",
  "identifier": "com.zenlist.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "zenlist",
        "width": 306,
        "height": 368,
        "minWidth": 240,
        "minHeight": 294,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true,
        "shadow": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/app-icon.png",
      "icons/icon.ico"
    ]
  }
}